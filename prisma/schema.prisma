generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model QueueItem {
  id        String   @id @default(cuid())
  title     String
  artist    String?
  url       String?
  addedBy   String?
  createdAt DateTime @default(now())
  order     Int?
  // processing state for safer worker semantics
  // stored as string in SQLite; treat as enum-like in application code
  status    String @default("PENDING")
  attempts  Int @default(0)
  lastAttemptAt DateTime?
}

model Song {
  id         String   @id
  title      String
  artist     String
  album      String?
  durationMs Int?
  albumArtUrl String?
  source     String?
  externalUrl String?
  createdAt  DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  songId    String
  userId    String?
  username  String
  voteType  String
  castAt    DateTime @default(now())
}

model Genre {
  id      Int      @id @default(autoincrement())
  name    String
  setBy   String
  setAt   DateTime @default(now())
  isActive Boolean @default(true)
}

model AdminState {
  id        Int      @id @default(autoincrement())
  username  String
  grantedAt DateTime @default(now())
  isActive  Boolean  @default(true)
}

model PlayHistory {
  id       String   @id @default(cuid())
  songId   String
  title    String
  artist   String?
  addedBy  String?
  playedAt DateTime @default(now())
}

