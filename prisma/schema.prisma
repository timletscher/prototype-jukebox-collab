generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model QueueItem {
  id        String   @id @default(cuid())
  title     String
  url       String?
  addedBy   String?
  createdAt DateTime @default(now())
  order     Int?
  // processing state for safer worker semantics
  // stored as string in SQLite; treat as enum-like in application code
  status    String @default("PENDING")
  attempts  Int @default(0)
  lastAttemptAt DateTime?
}

