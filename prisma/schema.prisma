generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QueueItem {
  id        String   @id @default(cuid())
  title     String
  url       String?
  addedBy   String?
  createdAt DateTime @default(now())
  order     Int?
  // processing state for safer worker semantics
  status    QueueStatus @default(PENDING)
  attempts  Int @default(0)
  lastAttemptAt DateTime?
}

enum QueueStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}
