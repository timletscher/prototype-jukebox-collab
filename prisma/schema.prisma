generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QueueItem {
  id        String   @id @default(cuid())
  title     String
  url       String?
  addedBy   String?
  createdAt DateTime @default(now())
  order     Int?     
}
