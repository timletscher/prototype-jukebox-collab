// Local SQLite schema (for dev fallback)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Copy of your models from prisma/schema.prisma
model QueueItem {
  id        String   @id @default(cuid())
  title     String
  artist    String?
  url       String?
  addedBy   String?
  createdAt DateTime @default(now())
  order     Int      @default(0)
  // status stored as text in SQLite local fallback
  status    String @default("PENDING")
  attempts  Int @default(0)
  lastAttemptAt DateTime?
}

model Song {
  id         String   @id
  title      String
  artist     String
  album      String?
  durationMs Int?
  albumArtUrl String?
  source     String?
  externalUrl String?
  createdAt  DateTime @default(now())
}

model Vote {
  id        String   @id @default(cuid())
  songId    String
  userId    String?
  username  String
  voteType  String
  castAt    DateTime @default(now())
}

model Genre {
  id      Int      @id @default(autoincrement())
  name    String
  setBy   String
  setAt   DateTime @default(now())
  isActive Boolean @default(true)
}

model AdminState {
  id        Int      @id @default(autoincrement())
  username  String
  grantedAt DateTime @default(now())
  isActive  Boolean  @default(true)
}

model PlayHistory {
  id       String   @id @default(cuid())
  songId   String
  title    String
  artist   String?
  addedBy  String?
  playedAt DateTime @default(now())
}

// Note: Postgres schema uses a native enum. Local SQLite stores `status` as text.
