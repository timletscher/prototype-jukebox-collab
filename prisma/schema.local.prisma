// Local SQLite schema (for dev fallback)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Copy of your models from prisma/schema.prisma
model QueueItem {
  id        String   @id @default(cuid())
  title     String
  url       String?
  addedBy   String?
  createdAt DateTime @default(now())
  order     Int      @default(0)
  // status stored as text in SQLite local fallback
  status    String @default("PENDING")
  attempts  Int @default(0)
  lastAttemptAt DateTime?
}

// Note: Postgres schema uses a native enum. Local SQLite stores `status` as text.
